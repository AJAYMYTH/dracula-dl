---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Dracula — A powerful YouTube downloader CLI + TUI powered by yt-dlp' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{title} — Dracula</title>
</head>
<body class="bg-canvas text-ink font-sans antialiased min-h-screen">
  <nav class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-2xl border-b border-hairline/50 h-16 flex items-center transition-all duration-300">
    <div class="max-w-[1400px] w-full mx-auto px-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-ink no-underline group">
        <span class="text-xl transition-transform duration-300 group-hover:scale-110">🧛</span>
        <span class="font-bold text-[15px] tracking-tight">Dracula</span>
        <span class="text-[10px] font-mono text-dracula-red bg-dracula-red-soft px-1.5 py-0.5 rounded-full border border-dracula-red/20">v1.0.4</span>
      </a>
      <div class="hidden md:flex items-center gap-1">
        <a href="/installation" class="px-3 py-1.5 text-[13px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all duration-200 no-underline">Installation</a>
        <a href="/cli" class="px-3 py-1.5 text-[13px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all duration-200 no-underline">CLI</a>
        <a href="/tui" class="px-3 py-1.5 text-[13px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all duration-200 no-underline">TUI</a>
        <a href="/commands" class="px-3 py-1.5 text-[13px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all duration-200 no-underline">Commands</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="https://github.com/AJAYMYTH/dracula-dl" target="_blank" rel="noopener" class="text-body hover:text-ink transition-all duration-200 hover:scale-110">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://pypi.org/project/dracula-dl/" target="_blank" rel="noopener" class="bg-dracula-red text-white text-[13px] font-semibold px-4 py-1.5 rounded-lg hover:bg-dracula-red-deep transition-all duration-200 hover:shadow-[0_0_20px_rgba(255,45,85,0.3)] no-underline">PyPI</a>
        <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-8 h-8 text-body hover:text-ink transition-colors" aria-label="Toggle menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden absolute top-16 left-0 right-0 bg-canvas-soft/95 backdrop-blur-xl border-b border-hairline/50 px-6 py-4 space-y-1">
      <a href="/installation" class="block px-4 py-2.5 text-[14px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all no-underline">Installation</a>
      <a href="/cli" class="block px-4 py-2.5 text-[14px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all no-underline">CLI</a>
      <a href="/tui" class="block px-4 py-2.5 text-[14px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all no-underline">TUI</a>
      <a href="/commands" class="block px-4 py-2.5 text-[14px] font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-lg transition-all no-underline">Commands</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="bg-canvas-soft border-t border-hairline/50 mt-32">
    <div class="max-w-[1400px] mx-auto px-6 py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <h4 class="font-mono text-[11px] font-medium text-dracula-red uppercase tracking-widest mb-4">Product</h4>
          <ul class="space-y-2.5">
            <li><a href="/installation" class="text-[13px] text-body hover:text-ink transition-colors no-underline">Installation</a></li>
            <li><a href="/cli" class="text-[13px] text-body hover:text-ink transition-colors no-underline">CLI Guide</a></li>
            <li><a href="/tui" class="text-[13px] text-body hover:text-ink transition-colors no-underline">TUI Guide</a></li>
            <li><a href="/commands" class="text-[13px] text-body hover:text-ink transition-colors no-underline">Commands</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-mono text-[11px] font-medium text-dracula-red uppercase tracking-widest mb-4">Resources</h4>
          <ul class="space-y-2.5">
            <li><a href="https://github.com/AJAYMYTH/dracula-dl" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">GitHub</a></li>
            <li><a href="https://pypi.org/project/dracula-dl/" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">PyPI</a></li>
            <li><a href="https://github.com/AJAYMYTH/dracula-dl/issues" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">Issues</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-mono text-[11px] font-medium text-dracula-red uppercase tracking-widest mb-4">Community</h4>
          <ul class="space-y-2.5">
            <li><a href="https://github.com/AJAYMYTH/dracula-dl" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">Contribute</a></li>
            <li><a href="https://github.com/AJAYMYTH/dracula-dl/issues" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">Report Bug</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-mono text-[11px] font-medium text-dracula-red uppercase tracking-widest mb-4">Legal</h4>
          <ul class="space-y-2.5">
            <li><a href="https://github.com/AJAYMYTH/dracula-dl/blob/main/LICENSE" target="_blank" rel="noopener" class="text-[13px] text-body hover:text-ink transition-colors no-underline">MIT License</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-hairline/50 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-[13px] text-muted">Made with <span class="text-dracula-red">❤</span> by <a href="https://github.com/AJAYMYTH" target="_blank" rel="noopener" class="text-body hover:text-ink transition-colors no-underline">Ajaymyth</a></p>
        <p class="text-[12px] text-muted font-mono">dracula-dl v1.0.4</p>
      </div>
    </div>
  </footer>
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fade-in-up');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
  </script>
</body>
</html>
