---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A powerful YouTube downloader CLI + TUI powered by yt-dlp. Download videos, audio, and playlists from the terminal.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title} — The Dracula</title>
  </head>
  <body class="bg-canvas-soft text-ink antialiased">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 h-16 border-b border-hairline bg-canvas/80 backdrop-blur-xl">
      <div class="mx-auto flex h-full max-w-6xl items-center justify-between px-6">
        <a href="/" class="flex items-center gap-2.5 text-ink no-underline">
          <span class="text-2xl">🧛</span>
          <span class="text-[15px] font-semibold tracking-tight">Dracula</span>
          <span class="rounded-full bg-canvas-soft-2 px-2 py-0.5 font-mono text-[11px] font-medium text-body">v1.0.4</span>
        </a>

        <div class="hidden items-center gap-1 md:flex">
          <a href="/getting-started" class:list={['rounded-full px-3.5 py-1.5 text-[13px] font-medium transition-colors', currentPath === '/getting-started' ? 'bg-ink text-ink-on' : 'text-body hover:text-ink']}>Get Started</a>
          <a href="/cli" class:list={['rounded-full px-3.5 py-1.5 text-[13px] font-medium transition-colors', currentPath === '/cli' ? 'bg-ink text-ink-on' : 'text-body hover:text-ink']}>CLI</a>
          <a href="/tui" class:list={['rounded-full px-3.5 py-1.5 text-[13px] font-medium transition-colors', currentPath === '/tui' ? 'bg-ink text-ink-on' : 'text-body hover:text-ink']}>TUI</a>
          <a href="/commands" class:list={['rounded-full px-3.5 py-1.5 text-[13px] font-medium transition-colors', currentPath === '/commands' ? 'bg-ink text-ink-on' : 'text-body hover:text-ink']}>Commands</a>
        </div>

        <div class="flex items-center gap-3">
          <a
            href="https://github.com/AJAYMYTH/dracula-dl"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-8 w-8 items-center justify-center rounded-full border border-hairline text-body transition-colors hover:text-ink"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a
            href="https://pypi.org/project/dracula-dl/"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden rounded-full bg-ink px-3.5 py-1.5 text-[13px] font-medium text-ink-on transition-opacity hover:opacity-90 sm:inline-block"
          >
            pip install dracula-dl
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="border-t border-hairline bg-canvas">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <div class="flex items-center gap-2.5">
              <span class="text-xl">🧛</span>
              <span class="text-sm font-semibold">Dracula</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-body">
              A powerful YouTube downloader CLI + TUI. Download videos, audio, and playlists from the terminal.
            </p>
          </div>
          <div>
            <h4 class="mb-3 font-mono text-[11px] font-medium uppercase tracking-wider text-mute">Product</h4>
            <ul class="space-y-2">
              <li><a href="/getting-started" class="text-sm text-body transition-colors hover:text-ink">Get Started</a></li>
              <li><a href="/cli" class="text-sm text-body transition-colors hover:text-ink">CLI Usage</a></li>
              <li><a href="/tui" class="text-sm text-body transition-colors hover:text-ink">TUI Interface</a></li>
              <li><a href="/commands" class="text-sm text-body transition-colors hover:text-ink">Commands</a></li>
            </ul>
          </div>
          <div>
            <h4 class="mb-3 font-mono text-[11px] font-medium uppercase tracking-wider text-mute">Resources</h4>
            <ul class="space-y-2">
              <li><a href="https://github.com/AJAYMYTH/dracula-dl" target="_blank" rel="noopener noreferrer" class="text-sm text-body transition-colors hover:text-ink">GitHub</a></li>
              <li><a href="https://pypi.org/project/dracula-dl/" target="_blank" rel="noopener noreferrer" class="text-sm text-body transition-colors hover:text-ink">PyPI</a></li>
              <li><a href="https://github.com/AJAYMYTH/dracula-dl/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-body transition-colors hover:text-ink">Report Issues</a></li>
            </ul>
          </div>
          <div>
            <h4 class="mb-3 font-mono text-[11px] font-medium uppercase tracking-wider text-mute">Legal</h4>
            <ul class="space-y-2">
              <li><a href="https://github.com/AJAYMYTH/dracula-dl/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-sm text-body transition-colors hover:text-ink">MIT License</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 flex items-center justify-between border-t border-hairline pt-8">
          <p class="text-xs text-mute">&copy; {new Date().getFullYear()} Dracula. Made with care.</p>
          <p class="text-xs text-mute">Powered by yt-dlp</p>
        </div>
      </div>
    </footer>
  </body>
</html>
